# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ============================================
# RESEND (emails)
# Créer compte gratuit sur resend.com — 100 emails/jour offerts
# ============================================
RESEND_API_KEY=re_YOUR_KEY

# ============================================
# STRIPE (paiements clients)
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# IDs des produits Stripe (créer dans Stripe Dashboard)
STRIPE_PRICE_STARTER=price_YOUR_STARTER_ID
STRIPE_PRICE_BUSINESS=price_YOUR_BUSINESS_ID
STRIPE_PRICE_PREMIUM=price_YOUR_PREMIUM_ID

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=https://votre-domaine.vercel.app
CRON_SECRET=GENERATE_RANDOM_32_CHAR_STRING

# ============================================
# NOTIFICATIONS (Telegram)
# Créer un bot via @BotFather sur Telegram
# ============================================
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ============================================
# GOOGLE PLACES API (scraping leads)
# Activer "Places API" sur console.cloud.google.com
# ============================================
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_KEY
